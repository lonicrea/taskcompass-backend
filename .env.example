# TaskCompass Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# ===========================================
# OpenAI API Configuration
# ===========================================
# Your OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API base URL
OPENAI_BASE_URL=https://api.openai.com/v1

# Model name to use
OPENAI_MODEL=gpt-4o-mini

# Legacy compatibility (optional)
# QWEN_API_KEY=
# QWEN_BASE_URL=
# QWEN_MODEL=

# ===========================================
# Application Configuration
# ===========================================
# Flask secret key for session encryption
SECRET_KEY=your_secret_key_here

# Server port
PORT=5000
FLASK_DEBUG=false

# ===========================================
# Token Limit Configuration
# ===========================================
# Daily token limit (0 = unlimited)
# Set to a number like 100000 to limit daily usage
DAILY_TOKEN_LIMIT=0

# ===========================================
# Frontend Configuration (Production)
# ===========================================
# Comma-separated origins allowed to call /api
CORS_ORIGINS=https://your-frontend-domain.com

# Optional compatibility key for single frontend origin
FRONTEND_URL=https://your-frontend-domain.com

# Persistent storage paths
TASKCOMPASS_DB_PATH=/app/data/clarity_ai.db
TASKCOMPASS_OUTPUT_DIR=/app/output
